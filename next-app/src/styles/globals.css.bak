:root {
  /* ── Color palette — retained ── */
  --bg:          #f9f6f0;
  --bg-alt:      #f2ede4;
  --bg-deep:     #111a11;
  --bg-deep-mid: #182018;
  --text:        #1c1c1c;
  --text-mid:    #3a3a3a;
  --text-muted:  #7a7a6e;
  --text-faint:  #a8a89a;
  --accent:      #c8922a;
  --accent-dim:  rgba(200,146,42,0.13);
  --rule:        #d6d0c4;
  --rule-faint:  #eae5dc;
  --card-bg:     #ffffff;

  /* ── Typography ── */
  --serif: 'Playfair Display', Georgia, serif;
  --sans:  'Source Sans 3', 'Helvetica Neue', Arial, sans-serif;

  /* ── Sidebar tokens ── */
  --sb-fg:    #e8e0d0;
  --sb-muted: rgba(232,224,208,0.45);
  --sb-faint: rgba(255,255,255,0.10);
  --sb-rule:  rgba(255,255,255,0.12);

  /* ── Card system ── */
  --radius-card:  24px;
  --radius-inner: 16px;
  --shadow-card:
    rgba(4,23,43,0.05) 0px 0px 0px 1px,
    rgba(0,0,0,0.10)  0px 20px 25px -5px,
    rgba(0,0,0,0.10)  0px 8px  10px -6px;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { font-size: 16px; }
body {
  font-family: var(--serif);
  background: var(--bg);
  color: var(--text);
  line-height: 1.55;
  overflow: hidden;
  height: 100vh;
}
button { cursor: pointer; font-family: inherit; background: none; border: none; }
select { font-family: inherit; }
a { color: inherit; text-decoration: none; }

::-webkit-scrollbar { width: 5px; height: 5px; }
::-webkit-scrollbar-track { background: var(--bg-alt); }
::-webkit-scrollbar-thumb { background: var(--rule); border-radius: 3px; }
::-webkit-scrollbar-thumb:hover { background: var(--accent); }

/* ── App shell ── */
.app { display: flex; height: 100vh; }

/* ── Sidebar ── */
.sidebar {
  width: 240px; min-width: 240px;
  background: var(--bg-deep);
  border-top: 3px solid var(--accent);
  display: flex; flex-direction: column;
  overflow-y: auto;
  position: relative; z-index: 10;
}
.sb-inner {
  padding: 24px 22px;
  flex: 1;
  display: flex; flex-direction: column;
}
.sb-overline {
  font-family: var(--sans);
  font-size: 0.58rem; font-weight: 600;
  letter-spacing: 0.3em; text-transform: uppercase;
  color: var(--accent); margin-bottom: 6px;
}
.sb-title {
  font-family: var(--serif); font-size: 1.1rem; font-weight: 400;
  color: var(--sb-fg); letter-spacing: 0.04em; line-height: 1.2;
}
.sb-subtitle {
  font-family: var(--serif);
  font-size: 0.72rem; font-style: italic;
  color: var(--sb-muted); margin-top: 4px;
}
.sb-divider { height: 1px; background: var(--sb-rule); margin: 18px 0; }
.sb-label {
  display: block;
  font-family: var(--serif);
  font-size: 0.65rem; font-style: italic;
  letter-spacing: 0.06em;
  color: var(--sb-muted); margin-bottom: 6px;
}
.sb-field { margin-bottom: 18px; }
.sb-select-wrap { position: relative; }
.sb-select-wrap::after {
  content: '▾'; position: absolute; right: 0; top: 50%;
  transform: translateY(-50%); color: var(--sb-muted);
  font-size: 0.7rem; pointer-events: none;
}
.sb-select-wrap select {
  width: 100%; appearance: none; background: transparent;
  border: none; border-bottom: 1px solid var(--sb-faint);
  color: var(--sb-fg);
  font-family: var(--sans); font-size: 0.82rem;
  padding: 5px 18px 5px 0; cursor: pointer; outline: none;
  transition: border-color 0.15s;
}
.sb-select-wrap select:focus { border-bottom-color: var(--accent); }
.sb-select-wrap select option { background: #182018; color: var(--sb-fg); }

.sb-metrics-heading {
  font-family: var(--serif);
  font-size: 0.65rem; font-style: italic;
  letter-spacing: 0.06em;
  color: var(--sb-muted); margin-bottom: 10px;
}
.sb-metrics-table { width: 100%; border-collapse: collapse; margin-bottom: 4px; }
.sb-metrics-table td {
  padding: 5px 0; border-bottom: 1px solid var(--sb-rule);
  font-size: 0.73rem;
}
.sb-metrics-table tr:last-child td { border-bottom: none; }
.sb-met-lbl { font-family: var(--serif); font-style: italic; color: var(--sb-muted); }
.sb-met-val {
  text-align: right;
  font-family: var(--sans);
  font-size: 0.9rem; font-weight: 500;
  color: var(--sb-fg);
}
.sb-met-val.accent { color: var(--accent); }
.sb-dr-row {
  display: flex; justify-content: space-between; align-items: baseline;
  padding: 5px 0; border-bottom: 1px solid var(--sb-rule);
}
.sb-dr-row:last-child { border-bottom: none; }
.sb-dr-lbl { font-family: var(--serif); font-size: 0.65rem; font-style: italic; color: var(--sb-muted); }
.sb-dr-val { font-family: var(--sans); font-size: 0.88rem; font-weight: 500; color: var(--sb-fg); }
.sb-dr-val.amber { color: var(--accent); }
.sb-footer {
  padding: 12px 22px; border-top: 1px solid var(--sb-rule);
  font-family: var(--serif);
  font-size: 0.62rem; font-style: italic; color: var(--text-faint); line-height: 1.7;
}

/* ── Main ── */
.main { flex: 1; display: flex; flex-direction: column; overflow: hidden; min-width: 0; }

/* ── Top nav ── */
.topnav {
  flex-shrink: 0; background: var(--bg-deep);
  display: flex; align-items: stretch; height: 52px; padding: 0 28px; gap: 0;
}
.nav-brand {
  display: flex; align-items: center;
  font-family: var(--serif); font-size: 0.95rem; font-style: italic;
  color: var(--sb-fg); letter-spacing: 0.04em; margin-right: 36px; white-space: nowrap;
}
.nav-brand span { color: var(--accent); margin: 0 6px; font-style: normal; }
.nav-tabs { display: flex; align-items: stretch; }
.tab-btn {
  display: flex; align-items: center;
  border-bottom: 2px solid transparent;
  padding: 0 22px;
  font-family: var(--serif); font-size: 0.82rem; font-style: italic;
  letter-spacing: 0.04em;
  color: var(--sb-muted); transition: color 0.15s, border-color 0.15s;
  white-space: nowrap;
}
.tab-btn:hover { color: var(--sb-fg); }
.tab-btn.active {
  color: #f0ebe0; border-bottom-color: var(--accent);
  font-weight: 600; font-style: normal;
}

/* ── Stat bar ── */
.stat-bar {
  flex-shrink: 0;
  display: flex; gap: 14px;
  padding: 16px 28px;
  background: var(--bg);
  border-bottom: 1px solid var(--rule-faint);
  overflow-x: auto;
}
.stat-card {
  flex: 1; min-width: 110px;
  padding: 16px 20px 14px;
  background: var(--card-bg);
  border-radius: var(--radius-card);
  box-shadow: var(--shadow-card);
}
.stat-val {
  font-family: var(--sans); font-size: 1.35rem; font-weight: 600;
  color: var(--text); line-height: 1; margin-bottom: 5px;
  letter-spacing: -0.01em;
}
.stat-lbl {
  font-family: var(--serif);
  font-size: 0.62rem; font-style: italic;
  letter-spacing: 0.04em; color: var(--text-muted);
}
.stat-sub {
  font-family: var(--serif);
  font-size: 0.6rem; font-style: italic; color: var(--text-faint); margin-top: 2px;
}

/* ── Content ── */
.content {
  flex: 1; overflow-y: auto;
  padding: 32px 36px 56px;
  background: var(--bg);
}
.tab-panel { animation: fadeIn 0.2s ease; }
@keyframes fadeIn { from { opacity: 0; transform: translateY(4px); } to { opacity: 1; } }

/* ── Section heads ── */
.section-head {
  display: flex; align-items: baseline; gap: 12px;
  margin: 36px 0 20px;
}
.section-head:first-child { margin-top: 0; }
.section-title {
  font-family: var(--serif); font-size: 1.15rem;
  font-weight: 400; color: var(--text); white-space: nowrap;
  letter-spacing: 0.01em;
}
.section-rule { flex: 1; height: 1px; background: var(--rule-faint); }
.district-tag {
  font-family: var(--sans);
  font-size: 0.6rem; font-weight: 600;
  letter-spacing: 0.1em; text-transform: uppercase;
  color: var(--accent); background: var(--accent-dim);
  padding: 3px 12px; border: 1px solid rgba(200,146,42,0.25);
  border-radius: 9999px;
  white-space: nowrap;
}

/* ── Charts ── */
.chart-wrap {
  background: var(--card-bg);
  border-radius: var(--radius-card);
  box-shadow: var(--shadow-card);
  padding: 8px 8px 4px;
  margin-bottom: 20px;
  overflow: hidden;
}
.chart-grid {
  display: grid; grid-template-columns: 1fr 1fr;
  gap: 20px; margin-bottom: 28px;
}

/* ── Fig cards ── */
.fig-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
.fig-card {
  background: var(--card-bg);
  border-radius: var(--radius-card);
  box-shadow: var(--shadow-card);
  overflow: hidden;
}
.fig-card img { width: 100%; display: block; }
.fig-caption { padding: 18px 22px 16px; }
.fig-label {
  font-family: var(--serif);
  font-size: 0.88rem; font-weight: 600; color: var(--text-mid);
  letter-spacing: 0.01em; margin-bottom: 8px;
}
.fig-toggle {
  display: inline-flex; align-items: center; gap: 5px;
  font-family: var(--serif);
  font-size: 0.72rem; font-style: italic;
  color: var(--text-muted);
  transition: color 0.15s; padding: 0; background: none; border: none;
}
.fig-toggle:hover { color: var(--accent); }
.fig-body {
  font-family: var(--serif);
  font-size: 0.82rem; color: var(--text-mid); line-height: 1.78;
  margin-top: 12px; padding: 14px 16px;
  background: var(--bg-alt);
  border-radius: var(--radius-inner);
  border-left: 2px solid var(--accent);
}

/* ── Metric cards ── */
.metric-row { display: grid; grid-template-columns: repeat(3,1fr); gap: 16px; margin-bottom: 24px; }
.metric-card {
  background: var(--card-bg);
  border-radius: var(--radius-card);
  box-shadow: var(--shadow-card);
  padding: 20px 24px 18px;
}
.mc-val {
  font-family: var(--sans); font-size: 1.5rem; font-weight: 600;
  color: var(--text); line-height: 1; margin-bottom: 6px;
  letter-spacing: -0.01em;
}
.mc-lbl {
  font-family: var(--serif);
  font-size: 0.65rem; font-style: italic;
  letter-spacing: 0.04em; color: var(--text-muted);
}
.mc-sub {
  font-family: var(--serif);
  font-size: 0.62rem; font-style: italic; color: var(--text-faint); margin-top: 3px;
}

/* ── Map frame ── */
.map-frame {
  width: 100%; height: 580px;
  border: none;
  border-radius: var(--radius-card);
  box-shadow: var(--shadow-card);
  display: block; margin-bottom: 36px;
  overflow: hidden;
}

/* ── Model cards ── */
.model-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 24px; }
.model-card {
  background: var(--card-bg);
  border-radius: var(--radius-card);
  box-shadow: var(--shadow-card);
  padding: 24px 28px;
}
.model-card-title {
  font-family: var(--serif);
  font-size: 0.78rem; font-style: italic;
  letter-spacing: 0.04em; color: var(--text-muted);
  margin-bottom: 16px; padding-bottom: 12px;
  border-bottom: 1px solid var(--rule-faint);
}
.model-stat {
  display: flex; justify-content: space-between; align-items: baseline;
  padding: 8px 0; border-bottom: 1px solid var(--rule-faint);
}
.model-stat:last-child { border-bottom: none; }
.s-label { font-family: var(--serif); font-size: 0.8rem; font-style: italic; color: var(--text-muted); }
.s-val { font-family: var(--sans); font-size: 1rem; font-weight: 500; color: var(--text); }
.s-val.accent { color: var(--accent); }

/* ── Panels ── */
.panel {
  font-family: var(--serif);
  padding: 16px 20px; font-size: 0.85rem; line-height: 1.8;
  color: var(--text-mid); margin-bottom: 20px;
  border-left: 2px solid var(--rule); background: var(--bg-alt);
  border-radius: 0 var(--radius-inner) var(--radius-inner) 0;
}
.panel.info   { border-left-color: #5c7fa6; background: #f2f5f8; }
.panel.amber  { border-left-color: var(--accent); background: #faf5ec; }

/* ── Breakdown table ── */
.data-card {
  background: var(--card-bg);
  border-radius: var(--radius-card);
  box-shadow: var(--shadow-card);
  overflow: hidden;
}
.data-card-head {
  padding: 16px 20px; border-bottom: 1px solid var(--rule-faint);
  font-family: var(--serif);
  font-size: 0.75rem; font-style: italic;
  letter-spacing: 0.04em; color: var(--text-muted);
}
.breakdown-table { width: 100%; border-collapse: collapse; font-size: 0.82rem; }
.breakdown-table th {
  text-align: left; padding: 10px 18px;
  font-family: var(--serif);
  font-size: 0.65rem; font-style: italic;
  letter-spacing: 0.06em; color: var(--text-muted);
  border-bottom: 1px solid var(--rule-faint); background: var(--bg-alt);
}
.breakdown-table td { padding: 10px 18px; border-bottom: 1px solid var(--rule-faint); }
.breakdown-table tr:last-child td { border-bottom: none; }
.badge {
  display: inline-block; padding: 3px 11px;
  font-family: var(--sans);
  font-size: 0.6rem; font-weight: 600;
  letter-spacing: 0.06em; text-transform: uppercase;
  border: 1px solid currentColor;
  border-radius: 9999px;
}
.badge-ctrl   { color: #3a6b3a; background: #eef5ee; }
.badge-unctrl { color: #7a3a3a; background: #f8eeee; }
.badge-struct { color: var(--text-muted); background: var(--bg-alt); }
.shap-pos { color: #2d5a2d; font-family: var(--sans); font-size: 0.9rem; font-weight: 500; }
.shap-neg { color: #7a3030; font-family: var(--sans); font-size: 0.9rem; font-weight: 500; }

/* ── Loading ── */
.loader {
  position: fixed; inset: 0; background: var(--bg);
  display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 16px;
}
.loader-ring {
  width: 40px; height: 40px; border: 2px solid var(--rule);
  border-top-color: var(--accent); border-radius: 50%;
  animation: spin 0.9s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }
.loader-text {
  font-family: var(--serif);
  font-size: 0.82rem; font-style: italic; letter-spacing: 0.06em;
  color: var(--text-muted);
}

/* ── Landing ── */
.landing {
  position: fixed; inset: 0; z-index: 100;
  display: flex; align-items: stretch; background: var(--bg);
}
.hero-left {
  flex: 0 0 60%; display: flex; flex-direction: column; justify-content: center;
  padding: 80px 72px 80px 96px; border-right: 1px solid var(--rule);
}
.hero-right {
  flex: 0 0 40%; display: flex; align-items: center; justify-content: center;
  background: var(--bg-alt); padding: 60px 48px; overflow: hidden;
}
.hero-overline {
  font-family: var(--sans);
  font-size: 0.65rem; font-weight: 600;
  letter-spacing: 0.22em; text-transform: uppercase;
  color: var(--text-muted); margin-bottom: 28px;
}
.hero-headline {
  font-family: var(--serif); font-size: clamp(2.4rem, 4.5vw, 3.8rem);
  font-weight: 400; line-height: 1.12; color: var(--text);
  letter-spacing: -0.02em; margin-bottom: 28px;
}
.hero-body {
  font-family: var(--serif);
  font-size: 0.98rem; color: var(--text-muted); line-height: 1.88;
  max-width: 500px; margin-bottom: 36px;
}
.hero-rule { width: 72px; height: 1px; background: var(--accent); margin-bottom: 32px; }
.hero-begin {
  display: inline-flex; align-items: center; gap: 8px;
  font-family: var(--serif);
  font-size: 0.88rem; font-style: italic;
  color: var(--accent);
  padding: 0; position: relative; transition: gap 0.2s;
}
.hero-begin::after {
  content: ''; position: absolute; bottom: -3px; left: 0; right: 0;
  height: 1px; background: var(--accent);
  transform: scaleX(0); transform-origin: left; transition: transform 0.25s ease;
}
.hero-begin:hover::after { transform: scaleX(1); }
.hero-begin:hover { gap: 14px; }
.hero-illustration { width: 100%; max-width: 340px; }

@media (max-width: 900px) {
  .hero-right { display: none; }
  .hero-left { flex: 1; padding: 48px 40px; }
  .sidebar { display: none; }
  .chart-grid { grid-template-columns: 1fr; }
  .fig-grid { grid-template-columns: 1fr; }
  .model-grid { grid-template-columns: 1fr; }
}
